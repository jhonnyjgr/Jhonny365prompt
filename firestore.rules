rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Test connection path
    match /test/connection {
      allow read: if true;
    }

    // 3. Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth helper using get() - Admin check
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin VIP';
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.username is string && data.username.size() >= 3 && data.username.size() <= 40
          && data.role in ['Regular', 'VIP', 'Admin VIP']
          && data.createdAt is timestamp;
      }

      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'Regular' && incoming().createdAt == request.time;
      allow update: if (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['profilePic', 'username', 'updatedAt']) && incoming().updatedAt == request.time)
                   || isAdmin();
    }

    // 2. Prompts Collection
    match /prompts/{promptId} {
      function isValidPrompt(data) {
        return data.title is string && data.title.size() <= 200
          && data.content is string && data.content.size() <= 10000
          && data.category is string
          && data.authorId == request.auth.uid
          && data.createdAt is timestamp;
      }

      allow read: if (existing().isPublic == true) || isOwner(existing().authorId) || isAdmin();
      allow list: if (resource.data.isPublic == true) || (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();
      
      allow create: if isSignedIn() && isValidPrompt(incoming()) && incoming().createdAt == request.time && isValidId(promptId);
      allow update: if isSignedIn() && (
        (isOwner(existing().authorId) && incoming().authorId == existing().authorId && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'category', 'isPublic', 'isVip', 'updatedAt']) && incoming().updatedAt == request.time)
        || (incoming().diff(existing()).affectedKeys().hasOnly(['copyCount']) && incoming().copyCount == existing().copyCount + 1)
        || isAdmin()
      );
      allow delete: if isOwner(existing().authorId) || isAdmin();
    }

    // 4. Conversations & Messages
    match /conversations/{conversationId} {
      function isParticipant(data) {
        return request.auth.uid == data.user1Id || request.auth.uid == data.user2Id;
      }

      allow get: if isSignedIn() && isParticipant(existing());
      allow list: if isSignedIn() && (resource.data.user1Id == request.auth.uid || resource.data.user2Id == request.auth.uid);
      
      allow create: if isSignedIn() && isParticipant(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isParticipant(existing()) && incoming().updatedAt == request.time;

      match /messages/{messageId} {
        function isValidMessage(data) {
          return data.content is string && data.content.size() <= 5000
            && data.senderId == request.auth.uid
            && data.createdAt is timestamp;
        }

        allow read, list: if isSignedIn() && isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)).data);
        allow create: if isSignedIn() && isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)).data) && isValidMessage(incoming()) && incoming().createdAt == request.time;
        allow update: if isSignedIn() && isOwner(existing().senderId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'isEdited', 'updatedAt']) && incoming().updatedAt == request.time;
        allow delete: if isOwner(existing().senderId) || isAdmin();
      }
    }
  }
}
