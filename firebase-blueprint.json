{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["Regular", "VIP", "Admin VIP"] },
        "vipUntil": { "type": "string", "format": "date-time" },
        "profilePic": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "role", "createdAt"]
    },
    "Prompt": {
      "title": "Prompt",
      "description": "An AI prompt shared or private",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "isVip": { "type": "boolean" },
        "copyCount": { "type": "integer" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "category", "authorId", "createdAt", "updatedAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat conversation between two users",
      "type": "object",
      "properties": {
        "user1Id": { "type": "string" },
        "user2Id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["user1Id", "user2Id", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a conversation",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "conversationId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isEdited": { "type": "boolean" },
        "isRead": { "type": "boolean" }
      },
      "required": ["content", "senderId", "receiverId", "conversationId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Profiles for registered users"
    },
    "/prompts/{promptId}": {
      "schema": "Prompt",
      "description": "Global collection of prompts"
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Conversation between two users"
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages belonging to a conversation"
    }
  }
}
